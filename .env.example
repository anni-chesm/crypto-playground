# ─────────────────────────────────────────────
#  CryptoPlayground — Environment Configuration
# ─────────────────────────────────────────────
#  Copy this file to .env and adjust values.
#  Never commit .env with real secrets.
# ─────────────────────────────────────────────

# ── Ports ────────────────────────────────────
# HTTPS port exposed to the host
APP_PORT=8001
# HTTP port (redirects to HTTPS)
APP_PORT_HTTP=8080
# Internal backend port (inside Docker network)
BACKEND_PORT=3000

# ── Security ──────────────────────────────────
# JWT signing secret — change this in production!
JWT_SECRET=crypto-playground-jwt-secret-change-me

# ── Environment ───────────────────────────────
NODE_ENV=production
